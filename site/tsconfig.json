{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"],
		},
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"types": ["@types/node", "./worker-configuration.d.ts", "../object.d.ts"],
	},
}
