---
interface Props {
	name: string;
	class?: string;
	style?: string;
}

const { name, class: className, style } = Astro.props;
---

<iconify-icon class={className} icon={name} {style} width="none"></iconify-icon>

<style is:global>
	@reference "../styles/global.css";

	iconify-icon:not([class^="size-"]):not([class*=" size-"]) {
		@apply size-4;
	}
</style>

<script src="iconify-icon"></script>
