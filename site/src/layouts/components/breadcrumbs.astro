---
interface Props {
	pathname: string;
}
---

<div class="breadcrumbs">
	<ul class="justify-center">
		<li>
			<a href="/" style="view-transition-name: site-heading">bandori-stats</a>
		</li>
		{
			Astro.props.pathname
				.split("/")
				.filter(Boolean)
				.map((path, idx, parts) => (
					<li style={`view-transition-name: site-path-${path}`}>
						{idx === parts.length - 1 ? (
							path
						) : (
							<a
								href={
									idx > 0 ? `/${parts.slice(0, idx + 1).join("/")}` : `/${path}`
								}
							>
								{path}
							</a>
						)}
					</li>
				))
		}
	</ul>
</div>
