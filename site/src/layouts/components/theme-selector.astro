---
import Icon from "~/components/icon.astro";
---

<button
	class="btn btn-primary max-sm:btn-circle"
	popovertarget="theme-selector"
>
	<span class="max-sm:hidden">Theme</span>
	<Icon class="size-5" name="lucide:palette" />
</button>
<ul
	class="dropdown dropdown-end mt-1 w-28"
	id="theme-selector"
	popover
	style="view-transition-name: theme-selector"
>
	<li>
		<label
			class="btn w-full justify-start btn-sm not-has-checked:btn-ghost has-checked:btn-primary"
		>
			<input class="hidden" name="theme-select" type="radio" value="latte" />
			<Icon name="lucide:sun" />
			Latte
		</label>
	</li>

	<li>
		<label
			class="btn w-full justify-start btn-sm not-has-checked:btn-ghost has-checked:btn-primary"
		>
			<input class="hidden" name="theme-select" type="radio" value="mocha" />
			<Icon name="lucide:moon" />
			Mocha
		</label>
	</li>
</ul>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const themeSelector =
			document.querySelector<HTMLElement>("#theme-selector")!;
		const triggerButton = document.querySelector<HTMLElement>(
			'[popovertarget="theme-selector"]',
		)!;

		const local = localStorage.getItem("theme");
		if (local) {
			const input = themeSelector.querySelector(`input[value="${local}"]`)!;
			if (input instanceof HTMLInputElement) input.checked = true;
		}

		const switchTheme = (theme: string) => {
			localStorage.setItem("theme", theme);
			const update = () => (document.documentElement.dataset.theme = theme);
			if (!document.startViewTransition) {
				update();
				return;
			}

			const rect = triggerButton.getBoundingClientRect();
			const cx = ((rect.left + rect.width / 2) / window.innerWidth) * 100;
			const cy = ((rect.top + rect.height / 2) / window.innerHeight) * 100;
			const radius = Math.hypot(
				Math.max(rect.x, window.innerWidth - rect.x),
				Math.max(rect.y, window.innerHeight - rect.y),
			);
			document.documentElement.style.setProperty("--tx", `${cx}%`);
			document.documentElement.style.setProperty("--ty", `${cy}%`);
			document.documentElement.style.setProperty("--radius", `${radius}px`);
			document.documentElement.classList.add("theme-transition");

			const transition = document.startViewTransition(update);
			transition.finished.finally(() => {
				document.documentElement.style.removeProperty("--tx");
				document.documentElement.style.removeProperty("--ty");
				document.documentElement.style.removeProperty("--radius");
				document.documentElement.classList.remove("theme-transition");
			});
		};

		themeSelector.addEventListener("input", (event) => {
			switchTheme((event.target as HTMLInputElement).value);
		});

		window
			.matchMedia("(prefers-color-scheme: dark)")
			.addEventListener("change", (event) => {
				const theme = event.matches ? "mocha" : "latte";
				themeSelector
					.querySelectorAll("input")
					.forEach((input) => (input.checked = input.value === theme));
				switchTheme(theme);
			});
	});
</script>

<style is:global>
	.theme-transition::view-transition-old(root) {
		animation: none;
	}

	.theme-transition::view-transition-new(root) {
		animation: reveal-circle 0.34s ease-in both;
		will-change: clip-path;
	}

	.theme-transition::view-transition {
		pointer-events: none;
	}

	@keyframes reveal-circle {
		from {
			clip-path: circle(0px at var(--tx) var(--ty));
		}
		to {
			clip-path: circle(var(--radius) at var(--tx) var(--ty));
		}
	}
</style>
