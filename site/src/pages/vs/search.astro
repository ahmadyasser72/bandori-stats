---
import { db } from "@bandori-stats/database";

import z from "zod";

import { idSchema } from "~/lib/schema";

export const partial = true;

const query = Astro.locals.query.query?.toString().replace("@", "") ?? "";
const side = z.enum(["player-1", "player-2"]).parse(Astro.locals.query.side);
const otherId = idSchema.optional().parse(Astro.locals.query.other);
const otherSide: typeof side = side === "player-1" ? "player-2" : "player-1";

const accounts = await db.query.accounts.findMany({
	columns: { id: true, username: true, nickname: true },
	limit: 24,
	orderBy: { lastUpdated: "desc", username: "asc" },
	where: {
		id: otherId ? { ne: otherId } : undefined,
		...(query && {
			OR: [
				{ username: { like: `%${query}%` } },
				{ nickname: { like: `%${query}%` } },
			],
		}),
	},
});
---

{
	accounts.map((account) => (
		<li>
			<button
				hx-get="/vs"
				hx-vals={JSON.stringify({ [side]: account.id, [otherSide]: otherId })}
				{...(otherId && {
					"data-umami-event": "compare-account",
					[`data-umami-event-${side}`]: account.id,
					[`data-umami-event-${otherSide}`]: otherId,
				})}
			>
				{account.nickname ? (
					<>
						@{account.username}
						<span class="opacity-50">({account.nickname})</span>
					</>
				) : (
					`@${account.username}`
				)}
			</button>
		</li>
	))
}
{
	accounts.length === 0 && (
		<li class="disabled">
			<a>No accounts found</a>
		</li>
	)
}
