---
import { db } from "@bandori-stats/database";

import z from "zod";

import { IdSchema, QuerySchema } from "~/lib/schema";

export const partial = true;

const {
	query,
	side,
	other: otherId,
} = Astro.locals.parseQuery(
	z.object({
		query: QuerySchema,
		side: z.enum(["player-1", "player-2"]),
		other: IdSchema.optional(),
	}),
);
const otherSide = side === "player-1" ? "player-2" : "player-1";

const accounts = await db.query.accounts.findMany({
	columns: { id: true, username: true, nickname: true },
	limit: 24,
	orderBy: { lastUpdated: "desc", username: "asc" },
	where: {
		id: otherId ? { ne: otherId } : {},
		...(query && {
			OR: [
				{ username: { like: `%${query}%` } },
				{ nickname: { like: `%${query}%` } },
			],
		}),
	},
});

if (Astro.cache.enabled) {
	Astro.cache.set({ etag: `"${__GIT_HASH__}"`, maxAge: 60 * 60 });
}
---

{
	accounts.map((account) => (
		<li>
			<button
				hx-get="/vs"
				hx-vals={JSON.stringify({ [side]: account.id, [otherSide]: otherId })}
				{...(otherId && {
					"data-umami-event": "compare-account",
					[`data-umami-event-${side}`]: account.id,
					[`data-umami-event-${otherSide}`]: otherId,
				})}
			>
				{account.nickname ? (
					<>
						@{account.username}
						<span class="opacity-50">({account.nickname})</span>
					</>
				) : (
					`@${account.username}`
				)}
			</button>
		</li>
	))
}
{
	accounts.length === 0 && (
		<li class="disabled">
			<a>No accounts found</a>
		</li>
	)
}
