---
import { db } from "@bandori-stats/database";

import { paginate } from "~/lib/paginate";
import { IdSchema } from "~/lib/schema";

export const partial = true;

const id = IdSchema.parse(Astro.params.id);
const snapshot = await db.query.accountSnapshots.findFirst({
	columns: { accountId: true, stats: true },
	where: { id },
	orderBy: { id: "desc" },
});

const titles = snapshot?.stats.titles ?? [];
const isNotFound = !snapshot || titles.length === 0;
if (isNotFound) Astro.response.status = 404;

const previous = isNotFound
	? undefined
	: await db.query.accountSnapshots.findFirst({
			columns: { stats: true },
			where: { id: { lt: id }, accountId: snapshot.accountId },
			orderBy: { id: "desc" },
		});

const previousTitles = new Set(previous?.stats.titles ?? []);
const sortedTitles = titles
	.map((id) => ({
		id,
		isNew: previousTitles.size === 0 || !previousTitles.has(id),
	}))
	.sort((a, b) => Number(b.isNew) - Number(a.isNew));
const hasNewTitle = sortedTitles.some(({ isNew }) => isNew);

const page = await paginate({
	items: sortedTitles,
	context: Astro,
	size: 96,
	extraProps: { "hx-swap": "afterend" },
});

if (!isNotFound && Astro.cache.enabled) {
	Astro.cache.set({ etag: `"${__GIT_HASH__}"`, maxAge: 60 * 60 * 24 * 365 });
}
---

{
	page.items.map(({ id, isNew }, idx) => (
		<img
			{...(page.isLastElement(idx) && page.props)}
			src={`/static/titles/${id}.webp`}
			class:list={[
				"aspect-23/5 skeleton rounded-2xl border border-base-content/67",
				hasNewTitle && !isNew && "opacity-34",
			]}
			loading="lazy"
		/>
	))
}
