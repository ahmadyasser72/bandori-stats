---
import { db } from "@bandori-stats/database";
import { accountSnapshots } from "@bandori-stats/database/schema";

import Icon from "~/components/icon.astro";
import { paginate } from "~/lib/paginate";
import { dateSchema } from "~/lib/schema";
import PopoverDropdown from "./_popover-dropdown.astro";
import { SnapshotCard } from "./_snapshot-card";

export const partial = true;

const date = dateSchema.unwrap().optional().parse(Astro.locals.query.date);

const page = await paginate({
	items: {
		get: async (limit, offset) => ({
			allSnapshotsCount: await db.$count(accountSnapshots),
			data: await db.query.accountSnapshots.findMany({
				limit,
				offset,
				where: { snapshotDate: date },
				columns: { accountId: true, id: true, snapshotDate: true, stats: true },
				orderBy: { snapshotDate: "desc", id: "desc" },
				with: {
					account: {
						columns: { username: true, nickname: true },
					},
				},
			}),
		}),
		hasNextPage: (limit, offset, it) => offset + limit < it.allSnapshotsCount,
	},
	context: Astro,
	size: 12,
	extraProps: {
		"hx-target": "closest .grid",
		"hx-swap": "beforeend",
	},
});

const currentSnapshots = page.items[0].data;
const previousSnapshots = (
	await db.query.accounts.findMany({
		columns: {},
		where: { id: { in: currentSnapshots.map(({ accountId }) => accountId) } },
		with: {
			snapshots: {
				columns: { accountId: true, stats: true, snapshotDate: true },
				orderBy: { snapshotDate: "desc" },
				where: { id: { lt: currentSnapshots.at(-1)!.id } },
				limit: 1,
			},
		},
	})
).flatMap(({ snapshots }) => snapshots);

const getPreviousSnapshot = ({
	accountId,
	id,
}: (typeof currentSnapshots)[number]) =>
	currentSnapshots.find((it) => it.accountId === accountId && it.id < id) ??
	previousSnapshots.find((it) => it.accountId === accountId);

const snapshots = currentSnapshots.map((snapshot) => ({
	...snapshot,
	previous: getPreviousSnapshot(snapshot),
}));
---

{
	snapshots.map(
		({ id, accountId, account, snapshotDate, stats, previous }, idx) => (
			<li class="contents" hx-vals={JSON.stringify({ account: accountId })}>
				<SnapshotCard
					{account}
					{previous}
					{snapshotDate}
					{stats}
					{...(page.isLastElement(idx) && page.props)}
				>
					<div
						class="card-actions justify-end"
						hx-disabled-elt=".card-actions button"
						style={`anchor-name: --anchor-${id}-actions`}
					>
						<button
							class="btn btn-soft btn-primary btn-sm"
							data-umami-event="view-calendar"
							data-umami-event-date={snapshotDate}
							data-umami-event-id={accountId}
							data-umami-event-username={account.username}
							popovertarget={`calendar-${id}`}
						>
							<Icon name="lucide:calendar" />
							Calendar
						</button>

						{stats.titles && (
							<button
								class="btn btn-soft btn-accent btn-sm"
								data-umami-event="view-titles"
								data-umami-event-date={snapshotDate}
								data-umami-event-id={accountId}
								data-umami-event-username={account.username}
								popovertarget={`titles-${id}`}
							>
								<Icon name="lucide:crown" />
								Titles
							</button>
						)}
					</div>

					<PopoverDropdown class="overflow-visible" {id} name="calendar">
						<div
							class="relative flex min-h-70 min-w-75 justify-center"
							hx-indicator={`#calendar-${id}-loader`}
						>
							<div
								hx-get={`/history/items/${id}/calendar`}
								hx-trigger="intersect once"
								hx-swap="outerHTML"
								hx-target="this"
							/>

							<div
								class="htmx-indicator absolute inset-0 bg-base-100/67"
								id={`calendar-${id}-loader`}
							>
								<Icon
									class="center absolute size-32"
									name="svg-spinners:bars-scale"
								/>
							</div>
						</div>
					</PopoverDropdown>

					{stats.titles && (
						<PopoverDropdown class="max-h-56 w-84" {id} name="titles">
							<div
								class="titles flex flex-wrap justify-center gap-x-1 gap-y-1.5 *:w-24 sm:*:w-32"
								hx-indicator="closest .titles"
							>
								<div
									hx-get={`/history/items/${id}/titles`}
									hx-trigger="intersect once"
									class="aspect-23/5 skeleton"
									hx-swap="outerHTML"
									hx-target="this"
								/>

								{Array.from(
									{ length: Math.min(stats.titles.length - 1, 5) },
									() => (
										<div class="htmx-indicator aspect-23/5 skeleton" />
									),
								)}
							</div>
						</PopoverDropdown>
					)}
				</SnapshotCard>
			</li>
		),
	)
}
